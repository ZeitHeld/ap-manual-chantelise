{
    "$schema": "https://raw.githubusercontent.com/ManualForArchipelago/Manual/main/schemas/Manual.options.schema.json",
    "_comment": "Add a _ before an option name to comment it out and it wont be added to the apworld",
    "core": {
        "goal":{
            "_comment": [
                "Using 'goal' as the name of an option let you override some of the generated goal parameters"
            ],
            "display_name": "The End Objective",
            "description": "How to End your Randomized playthrough.",
            "aliases": {"easiest": 0},
            "hidden": false,
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template"
            ]
        },
        "death_link": {
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true
        },
        "filler_traps": {
            "_comment": "Using values here let you set a 'recommended' filler_trap percentage or even a default percentage",
            "values": {
                "recommended": 20
            }
        }
    },
    "user": {
        "_commented_out_option":{
            "type": "Toggle",
            "default": true
        },
        "_Example_Range":{
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 0,
            "default": 1,
            "range_end": 5,
            "values": {"example": 2},
            "group": "Example Options"
        },

        "progressive_dungeons":{
            "display_name": "Progressive Dungeons",
            "description": [
                "Dungeons are progressive, meaning you get the Dungeons in order. Survival Dungeon and Familair Forest Exluded.",
                "Order: Terran -> Ignan -> Aquan -> Zephyran -> Sealed Palace"],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "Gameplay Options"
        },
        "stagesanity":{
            "display_name": "Stagesanity",
            "description": "Requires the individual stages to be unlocked. Completing a stage gives a reward and Stage unlocks need to be found.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Gameplay Options"
        },
        "progressive_stages":{
            "display_name": "Progressive Stages",
            "description": [
                "Does nothing if Stagesanity is disabled.",
                "Stages are progressive, meaning you need to complete earlier stages to unlock later ones. Stages are progressive per dungeon."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "Gameplay Options"
        },
        "progressive_equipment":{
            "display_name": "Progressive Equipment",
            "description": "Option to make the four main Equipment types progressive. It will simplify logic but will shrink the item pool.\nLeather Gloves -> Tough Gloves -> Silver Gauntlet | Souvenier Charm -> Standard Charm -> Popular Charm\nElemental Shields and Charms are still separate and not included in progression.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Gameplay Options"
        },
        "shop_shuffle":{
            "display_name": "Shop Shuffle",
            "description": "Fish Trades from the Fisherman in Plains gives other Rewards.",
            "type": "Choice",
            "values": {
                "none": 0,
                "aira_only": 1,
                "include_merchant": 2,
                "both_dungeon": 3
            },
            "aliases": {
                "aira": 1,
                "aira_&_merchant": 2,
                "aira_merchant": 2,
                "merchant": 2,
                "both": 2,
                "dungeon": 3,
                "include_dungeon": 3,
                "aira_merchant_dungeon": 3
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": 2,
            "group": "Randomization Options"
        },
        "shop_sell_unlock":{
            "display_name": "Shop Sell Unlock Shuffle",
            "description": "Fish Trades from the Fisherman in Plains gives other Rewards.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "Randomization Options"
        },
        "fish_trade":{
            "display_name": "Fish Trading",
            "description": "Fish Trades from the Fisherman in Plains gives other Rewards.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "Randomization Options"
        },
        "fishsanity":{
            "display_name": "Fishsanity",
            "description": "Includes First Time Catching a Fish as a Check.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Randomization Options"
        },
        "spellsanity":{
            "display_name": "Spellsanity",
            "description": "Adds in the Tier III and IV Spells into the pool.",
            "type": "Choice",
            "values": {
                "none": 0,
                "regular": 1,
                "include_tier2": 2
            },
            "aliases": {
                "tier3-4": 1,
                "tier2-4": 2,
                "tier3": 1,
                "tier2": 2,
                "3-4": 1,
                "2-4": 2
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": 0,
            "group": "Randomization Options"
        },
        "barrelsanity":{
            "display_name": "Barrelsanity",
            "description": "Breaking a Barrel sends an item.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Randomization Options"
        }
    }

}
