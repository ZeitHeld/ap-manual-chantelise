  "Aquan Ruins": {
    "connects_to": [
      "Map"
    ],
    "requires": "|Aquan Ruins Access|"
  },
  "Zephyran Ruins": {
    "connects_to": [
      "Map"
    ],
    "requires": "|Zephyran Ruins Access|"
  },
  "Sealed Palace": {
    "connects_to": [
      "Map"
